# ── Database ─────────────────────────────────────────────────
DB_USER=typer
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=typerdb

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=Typer.Api
JWT_AUDIENCE=Typer.Client
JWT_EXPIRATION_MINUTES=120

# ── API-Football (wyniki live) ────────────────────────────────
# Klucz z https://www.api-football.com/ — włącz Enabled=true na produkcji
API_FOOTBALL_ENABLED=false
API_FOOTBALL_API_KEY=
