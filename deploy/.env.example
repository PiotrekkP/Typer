# ── Database ─────────────────────────────────────────────────
DB_USER=typer
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=typerdb

# ── Site (nginx) ──────────────────────────────────────────────
SITE_DOMAIN=cozatypy.pl

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ISSUER=Typer.Api
JWT_AUDIENCE=Typer.Client
JWT_EXPIRATION_MINUTES=120

# ── Admin panel ───────────────────────────────────────────────
ADMIN_EMAIL=piotr.paluszek1@gmail.com

# ── VIP ranking (opcjonalnie — e-maile z dostępem do /ranking/vip) ──
# VIP_EMAIL=gracz@example.com

# ── football-data.org live (matches?status=LIVE) — token z api.football-data.org (nagłówek X-Auth-Token) ──
FOOTBALL_DATA_ENABLED=true
FOOTBALL_DATA_AUTH_TOKEN=
FOOTBALL_DATA_POLL_INTERVAL_SECONDS=60
FOOTBALL_DATA_DISCOVERY_POLL_INTERVAL_SECONDS=60
FOOTBALL_DATA_DISCOVERY_MAX_ATTEMPTS=10
