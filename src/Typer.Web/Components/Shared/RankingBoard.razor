@using Typer.Application.Rankings.DTOs
@using Typer.Application.Rankings.Interfaces
@inject IRankingService RankingService

<div class="ranking-page">

    <div class="ranking-header">
        <h1 class="ranking-title">@Title</h1>
        <p class="ranking-subtitle">@Subtitle</p>
    </div>

    @if (_ranking is null)
    {
        <p class="loading">Ładowanie rankingu…</p>
    }
    else if (_ranking.Count == 0)
    {
        <p class="ranking-empty">@EmptyMessage</p>
    }
    else
    {
        @if (_ranking.Count >= 1)
        {
            <div class="podium">
                @foreach (var entry in _ranking.Take(Math.Min(3, _ranking.Count)))
                {
                    <div class="podium__place podium__place--@entry.Position">
                        <div class="podium__medal">@MedalIcon(entry.Position)</div>
                        @if (!string.IsNullOrEmpty(entry.TeamFlagUrl))
                        {
                            <img src="@entry.TeamFlagUrl" alt="@entry.TeamName" class="podium__flag" />
                        }
                        <a href="/gracz/@entry.UserId" class="podium__name">@entry.DisplayName</a>
                        <div class="podium__points">@entry.TotalPoints pkt</div>
                    </div>
                }
            </div>
        }

        <div class="ranking-table-wrapper">
            <table class="ranking-table">
                <thead>
                    <tr>
                        <th class="col-pos">#</th>
                        <th class="col-player">Gracz</th>
                        <th class="col-team">Reprezentacja</th>
                        <th class="col-player-name">Zawodnik</th>
                        <th class="col-pts" title="Łączne punkty">Suma</th>
                        <th class="col-pts col-pts--sub" title="Punkty z typowania wyników">⚽ Typy</th>
                        <th class="col-pts col-pts--sub" title="Bonus za drużynę (×2)">★ Drużyna</th>
                        <th class="col-pts col-pts--sub" title="Gole ulubionego zawodnika">👟 Gole</th>
                        <th class="col-pts col-pts--sub" title="Bonus za mistrzostwo">🏆 Mistrz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _ranking)
                    {
                        <tr class="ranking-row ranking-row--@MedalClass(entry.Position)">
                            <td class="col-pos">
                                <span class="position-badge position-badge--@MedalClass(entry.Position)">
                                    @(entry.Position <= 3 ? MedalIcon(entry.Position) : entry.Position.ToString())
                                </span>
                            </td>
                            <td class="col-player">
                                <a href="/gracz/@entry.UserId" class="player-link">@entry.DisplayName</a>
                            </td>
                            <td class="col-team">
                                <span class="col-team__inner">
                                    @if (!string.IsNullOrEmpty(entry.TeamFlagUrl))
                                    {
                                        <img src="@entry.TeamFlagUrl" alt="@entry.TeamName" class="table-flag" />
                                    }
                                    <span>@(entry.TeamName ?? "—")</span>
                                </span>
                            </td>
                            <td class="col-player-name">@(entry.PlayerName ?? "—")</td>
                            <td class="col-pts total-pts">@entry.TotalPoints</td>
                            <td class="col-pts sub-pts">@entry.PredictionPoints</td>
                            <td class="col-pts sub-pts">@entry.TeamBonusPoints</td>
                            <td class="col-pts sub-pts">@entry.PlayerGoalPoints</td>
                            <td class="col-pts sub-pts">@entry.TournamentWinnerPoints</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ranking-legend">
            <span>⚽ Typy — punkty za trafione wyniki</span>
            <span>★ Drużyna — bonus ×2 za mecze ulubionej reprezentacji</span>
            <span>👟 Gole — +3 pkt za każdy gol ulubionego zawodnika</span>
            <span>🏆 Mistrz — +20 pkt jeśli Twoja drużyna wygra turniej</span>
        </div>
    }

</div>

@code {
    [Parameter] public bool VipOnly { get; set; }
    [Parameter] public string Title { get; set; } = "Ranking punktowy";
    [Parameter] public string Subtitle { get; set; } = "Podział punktów według kategorii typowania";
    [Parameter] public string EmptyMessage { get; set; } = "Ranking jest pusty — nikt jeszcze nie typował.";

    private IReadOnlyList<RankingEntryDto>? _ranking;

    protected override async Task OnInitializedAsync()
    {
        _ranking = await RankingService.GetLeaderboardAsync(VipOnly);
    }

    private static string MedalIcon(int pos) => pos switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => pos.ToString()
    };

    private static string MedalClass(int pos) => pos switch
    {
        1 => "gold",
        2 => "silver",
        3 => "bronze",
        _ => "other"
    };
}
