@using Typer.Application.Matches.Interfaces
@using Typer.Application.Rankings.DTOs
@using Typer.Application.Rankings.Interfaces
@using Typer.Application.Scoring
@implements IAsyncDisposable
@inject IRankingService RankingService
@inject IMatchService MatchService
@inject IWebHostEnvironment HostEnvironment

<div class="ranking-page">

    <div class="ranking-header">
        <h1 class="ranking-title">@Title</h1>
        <p class="ranking-subtitle">
            @Subtitle
            @if (_liveRefreshActive)
            {
                <span class="ranking-live-hint"> · mecze na żywo — odświeżanie co @RefreshIntervalSeconds s</span>
            }
            else
            {
                <span class="ranking-live-hint ranking-live-hint--muted"> · odświeżanie co @RefreshIntervalSeconds s</span>
            }
        </p>
        @if (_ranking is not null && _ranking.Count > 0)
        {
            <div class="ranking-actions">
                <button type="button" class="ranking-refresh-btn" disabled="@_refreshing" @onclick="ManualRefreshAsync">
                    @(_refreshing ? "Odświeżanie…" : "Odśwież teraz")
                </button>
                <button type="button" class="ranking-refresh-btn ranking-refresh-btn--secondary" disabled="@_refreshing" @onclick="ResetBaselineAsync">
                    Ustaw stan odniesienia
                </button>
            </div>
            <p class="ranking-hint">Test lokalny: ustaw stan odniesienia → zmień wynik/punkty → odśwież. W Δ pojawi się ↑/↓.</p>
        }
    </div>

    @if (_ranking is null)
    {
        <p class="loading">Ładowanie rankingu…</p>
    }
    else if (_ranking.Count == 0)
    {
        <p class="ranking-empty">@EmptyMessage</p>
    }
    else
    {
        @if (_ranking.Count >= 1)
        {
            <div class="podium">
                @foreach (var entry in _ranking.Take(Math.Min(3, _ranking.Count)))
                {
                    var delta = GetDelta(entry.UserId);
                    <div class="podium__place podium__place--@entry.Position">
                        <div class="podium__medal">@MedalIcon(entry.Position)</div>
                        @if (!string.IsNullOrEmpty(entry.TeamFlagUrl))
                        {
                            <img src="@entry.TeamFlagUrl" alt="@entry.TeamName" class="podium__flag" />
                        }
                        <a href="/gracz/@entry.UserId" class="podium__name">@entry.DisplayName</a>
                        <div class="podium__points">@entry.TotalPoints pkt</div>
                        @if (delta is not null)
                        {
                            <span class="position-delta position-delta--@(delta > 0 ? "up" : "down")">
                                <span class="position-delta__arrow">@(delta > 0 ? "↑" : "↓")</span><span class="position-delta__num">@Math.Abs(delta.Value)</span>
                            </span>
                        }
                    </div>
                }
            </div>
        }

        <div class="ranking-table-wrapper">
            <table class="ranking-table">
                <thead>
                    <tr>
                        <th class="col-pos">#</th>
                        <th class="col-delta" title="Zmiana pozycji od poprzedniego odświeżenia">Δ</th>
                        <th class="col-player">Gracz</th>
                        <th class="col-team">Reprezentacja</th>
                        <th class="col-player-name">Zawodnik</th>
                        <th class="col-pts" title="Łączne punkty">Suma</th>
                        <th class="col-pts col-pts--sub" title="Punkty z typowania wyników">⚽ Typy</th>
                        <th class="col-pts col-pts--sub" title="Bonus za drużynę (×2)">★ Drużyna</th>
                        <th class="col-pts col-pts--sub" title="Gole ulubionego zawodnika">👟 Gole</th>
                        <th class="col-pts col-pts--sub" title="Bonus za mistrzostwo">🏆 Mistrz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _ranking)
                    {
                        var positionDelta = GetDelta(entry.UserId);
                        <tr class="ranking-row ranking-row--@MedalClass(entry.Position)">
                            <td class="col-pos">
                                <span class="position-badge position-badge--@MedalClass(entry.Position)">
                                    @(entry.Position <= 3 ? MedalIcon(entry.Position) : entry.Position.ToString())
                                </span>
                            </td>
                            <td class="col-delta">
                                @if (positionDelta is int delta)
                                {
                                    <span class="position-delta position-delta--@(delta > 0 ? "up" : "down")"
                                          title="Zmiana pozycji od poprzedniego odświeżenia">
                                        <span class="position-delta__arrow">@(delta > 0 ? "↑" : "↓")</span><span class="position-delta__num">@Math.Abs(delta)</span>
                                    </span>
                                }
                                else
                                {
                                    <span class="position-delta position-delta--none">—</span>
                                }
                            </td>
                            <td class="col-player">
                                <a href="/gracz/@entry.UserId" class="player-link">@entry.DisplayName</a>
                            </td>
                            <td class="col-team">
                                <span class="col-team__inner">
                                    @if (!string.IsNullOrEmpty(entry.TeamFlagUrl))
                                    {
                                        <img src="@entry.TeamFlagUrl" alt="@entry.TeamName" class="table-flag" />
                                    }
                                    <span>@(entry.TeamName ?? "—")</span>
                                </span>
                            </td>
                            <td class="col-player-name">@(entry.PlayerName ?? "—")</td>
                            <td class="col-pts total-pts">@entry.TotalPoints</td>
                            <td class="col-pts sub-pts">@entry.PredictionPoints</td>
                            <td class="col-pts sub-pts">@entry.TeamBonusPoints</td>
                            <td class="col-pts sub-pts">@entry.PlayerGoalPoints</td>
                            <td class="col-pts sub-pts">@entry.TournamentWinnerPoints</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ranking-legend">
            <span>⚽ Typy — punkty za trafione wyniki</span>
            <span>★ Drużyna — bonus ×2 za mecze ulubionej reprezentacji</span>
            <span>👟 Gole — +3 pkt za każdy gol ulubionego zawodnika</span>
            <span>🏆 Mistrz — +20 pkt jeśli Twoja drużyna wygra turniej</span>
            <span>↑↓ — zmiana pozycji od poprzedniego odświeżenia (gdy ktoś zdobył/stracił punkty)</span>
        </div>
    }

</div>

@code {
    [Parameter] public bool VipOnly { get; set; }
    [Parameter] public string Title { get; set; } = "Ranking punktowy";
    [Parameter] public string Subtitle { get; set; } = "Podział punktów według kategorii typowania";
    [Parameter] public string EmptyMessage { get; set; } = "Ranking jest pusty — nikt jeszcze nie typował.";

    private IReadOnlyList<RankingEntryDto>? _ranking;
    private Dictionary<string, int> _positionDeltas = new();
    private bool _hasBaseline;
    private bool _liveRefreshActive;
    private bool _refreshing;

    private RankingSnapshot? _previousSnapshot;
    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _refreshCts;

    private TimeSpan RefreshInterval =>
        HostEnvironment.IsDevelopment()
            ? TimeSpan.FromSeconds(15)
            : LiveScoringRules.RefreshInterval;

    private int RefreshIntervalSeconds => (int)RefreshInterval.TotalSeconds;

    protected override async Task OnInitializedAsync()
    {
        await CaptureBaselineAsync();
        StartRefreshTimer();
    }

    private async Task CaptureBaselineAsync()
    {
        var fresh = await RankingService.GetLeaderboardAsync(VipOnly);
        _previousSnapshot = RankingSnapshot.From(fresh);
        _hasBaseline = true;
        _positionDeltas.Clear();
        _ranking = fresh;
        _liveRefreshActive = await MatchService.HasInProgressMatchesAsync();
    }

    private async Task RefreshRankingAsync()
    {
        if (!_hasBaseline || _previousSnapshot is null)
        {
            await CaptureBaselineAsync();
            return;
        }

        var fresh = await RankingService.GetLeaderboardAsync(VipOnly);
        _liveRefreshActive = await MatchService.HasInProgressMatchesAsync();
        _ranking = fresh;

        var activity = HasRankingActivity(_previousSnapshot, fresh);
        if (!activity)
            return;

        var newDeltas = ComputeDeltas(_previousSnapshot, fresh);
        if (newDeltas.Count > 0)
            _positionDeltas = newDeltas;
        else
            _positionDeltas.Clear();

        _previousSnapshot = RankingSnapshot.From(fresh);
    }

    private async Task ResetBaselineAsync()
    {
        _refreshing = true;
        try
        {
            await CaptureBaselineAsync();
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _refreshing = false;
        }
    }

    private async Task ManualRefreshAsync()
    {
        _refreshing = true;
        try
        {
            await RefreshRankingAsync();
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _refreshing = false;
        }
    }

    private static Dictionary<string, int> ComputeDeltas(
        RankingSnapshot previous,
        IReadOnlyList<RankingEntryDto> current)
    {
        var oldRanks = ComputeRanks(current, previous.Points);
        var newRanks = ComputeRanks(current);
        var deltas = new Dictionary<string, int>(StringComparer.Ordinal);

        foreach (var entry in current)
        {
            if (!oldRanks.TryGetValue(entry.UserId, out var oldPosition))
                continue;
            if (!newRanks.TryGetValue(entry.UserId, out var newPosition))
                continue;

            var delta = oldPosition - newPosition;
            if (delta != 0)
                deltas[entry.UserId] = delta;
        }

        return deltas;
    }

    private static Dictionary<string, int> ComputeRanks(
        IReadOnlyList<RankingEntryDto> entries,
        Dictionary<string, int> pointsByUser)
    {
        var ranks = new Dictionary<string, int>(StringComparer.Ordinal);
        var ordered = entries
            .Select(e => (e.UserId, e.DisplayName, Points: pointsByUser.GetValueOrDefault(e.UserId, e.TotalPoints)))
            .OrderByDescending(x => x.Points)
            .ThenBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.UserId, StringComparer.Ordinal)
            .ToList();

        for (var i = 0; i < ordered.Count; i++)
            ranks[ordered[i].UserId] = i + 1;

        return ranks;
    }

    private static Dictionary<string, int> ComputeRanks(IReadOnlyList<RankingEntryDto> entries) =>
        ComputeRanks(entries, entries.ToDictionary(e => e.UserId, e => e.TotalPoints, StringComparer.Ordinal));

    private static bool HasRankingActivity(
        RankingSnapshot previous,
        IReadOnlyList<RankingEntryDto> current)
    {
        foreach (var entry in current)
        {
            if (!previous.Points.TryGetValue(entry.UserId, out var oldPoints))
                continue;

            if (entry.TotalPoints != oldPoints)
                return true;
        }

        return false;
    }

    private void StartRefreshTimer()
    {
        if (_refreshTimer is not null)
            return;

        _refreshCts = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(RefreshInterval);
        _ = RunRefreshLoopAsync(_refreshCts.Token);
    }

    private void StopRefreshTimer()
    {
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        _refreshCts = null;
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _refreshTimer!.WaitForNextTickAsync(ct))
            {
                await RefreshRankingAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private int? GetDelta(string userId)
    {
        if (!_positionDeltas.TryGetValue(userId, out var delta) || delta == 0)
            return null;

        return delta;
    }

    public async ValueTask DisposeAsync()
    {
        StopRefreshTimer();
        await Task.CompletedTask;
    }

    private static string MedalIcon(int pos) => pos switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => pos.ToString()
    };

    private static string MedalClass(int pos) => pos switch
    {
        1 => "gold",
        2 => "silver",
        3 => "bronze",
        _ => "other"
    };

    private sealed record RankingSnapshot(Dictionary<string, int> Points)
    {
        public static RankingSnapshot From(IReadOnlyList<RankingEntryDto> entries) =>
            new(entries.ToDictionary(e => e.UserId, e => e.TotalPoints, StringComparer.Ordinal));
    }
}
