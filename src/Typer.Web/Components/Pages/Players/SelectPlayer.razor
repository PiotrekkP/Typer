@page "/zawodnicy"
@rendermode InteractiveServer
@using System.Security.Claims
@using Typer.Application.Players.DTOs
@using Typer.Application.Players.Interfaces
@using Typer.Application.UserProfile.DTOs
@using Typer.Application.UserProfile.Interfaces
@inject IPlayerService PlayerService
@inject IUserProfileService UserProfileService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Zawodnicy — Typer</PageTitle>

<div class="selection-page">

    <div class="selection-header">
        <h1 class="selection-title">Wybierz zawodnika</h1>
        <p class="selection-subtitle">
            Każdy gol Twojego zawodnika to +3 pkt w rankingu!
        </p>
    </div>

    @if (!_isAuthenticated)
    {
        <div class="selection-auth-prompt">
            <p>Musisz być <a href="/logowanie">zalogowany</a>, żeby wybrać zawodnika.</p>
        </div>
    }
    else if (_selection?.SelectedTeamId is null)
    {
        <div class="selection-auth-prompt">
            <p>Najpierw <a href="/reprezentacje">wybierz reprezentację</a>, a potem wskaż zawodnika.</p>
        </div>
    }
    else
    {
        <div class="current-selection">
            <span class="current-selection__label">Reprezentacja:</span>
            <span class="current-selection__value">
                @_selection.SelectedTeamName (@_selection.SelectedTeamCode)
            </span>
            @if (_selection.SelectedPlayerId is not null)
            {
                <span class="current-selection__player">
                    · Twój zawodnik: #@_selection.SelectedPlayerNumber @_selection.SelectedPlayerName
                </span>
            }
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="selection-feedback selection-feedback--@(_isError ? "error" : "success")">
                @_message
            </div>
        }

        @if (_players is null)
        {
            <p class="loading">Ładowanie składu…</p>
        }
        else if (_players.Count == 0)
        {
            <p>Brak zawodników w tej drużynie.</p>
        }
        else
        {
            <div class="players-grid">
                @foreach (var player in _players)
                {
                    var isSelected = _selection?.SelectedPlayerId == player.Id;
                    <button class="player-card @(isSelected ? "player-card--selected" : "")"
                            @onclick="() => SelectPlayerAsync(player)">

                        <span class="player-card__number">#@player.JerseyNumber</span>

                        <div class="player-card__info">
                            <span class="player-card__name">
                                @player.FirstName @player.LastName
                            </span>
                            @if (!string.IsNullOrEmpty(player.Position))
                            {
                                <span class="player-card__position">@PositionLabel(player.Position)</span>
                            }
                            @if (!string.IsNullOrEmpty(player.Club))
                            {
                                <span class="player-card__club">@player.Club</span>
                            }
                        </div>

                        @if (isSelected)
                        {
                            <span class="player-card__check">✓</span>
                        }
                    </button>
                }
            </div>
        }
    }

</div>

@code {
    private IReadOnlyList<PlayerDto>? _players;
    private UserSelectionDto? _selection;
    private bool _isAuthenticated;
    private string? _userId;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        _userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (_userId is not null)
        {
            _selection = await UserProfileService.GetSelectionAsync(_userId);

            if (_selection?.SelectedTeamId is not null)
                _players = await PlayerService.GetByTeamAsync(_selection.SelectedTeamId.Value);
        }
    }

    private async Task SelectPlayerAsync(PlayerDto player)
    {
        if (_userId is null) return;

        var result = await PlayerService.SelectPlayerAsync(_userId, new SelectPlayerRequest(player.Id));

        if (result.Succeeded)
        {
            _message = $"Wybrano: #{player.JerseyNumber} {player.FirstName} {player.LastName}";
            _isError = false;
            _selection = await UserProfileService.GetSelectionAsync(_userId);
        }
        else
        {
            _message = result.Error ?? "Wystąpił błąd.";
            _isError = true;
        }
    }

    private static string PositionLabel(string pos) => pos.ToUpper() switch
    {
        "GK" or "GOALKEEPER" or "BRAMKARZ"  => "Bramkarz",
        "DEF" or "DEFENDER"  or "OBROŃCA"   => "Obrońca",
        "MID" or "MIDFIELDER" or "POMOCNIK" => "Pomocnik",
        "FWD" or "FORWARD"   or "NAPASTNIK" => "Napastnik",
        _ => pos
    };
}
