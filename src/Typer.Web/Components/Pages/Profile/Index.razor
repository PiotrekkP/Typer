@page "/gracz/{UserId}"
@page "/profil"
@using Typer.Application.Players.DTOs
@using Typer.Application.Players.Interfaces
@using Typer.Application.Teams.DTOs
@using Typer.Application.Teams.Interfaces
@using Typer.Application.UserProfile.DTOs
@implements IDisposable

@inject IUserProfileService UserProfileService
@inject ITeamService TeamService
@inject IPlayerService PlayerService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>@PageTitleText — Typer</PageTitle>

@if (_loading)
{
    <div class="profile-loading">Ładowanie profilu…</div>
}
else if (_profile is null)
{
    <div class="profile-not-found">
        <p>Nie znaleziono gracza.</p>
        <a href="/ranking">Wróć do rankingu</a>
    </div>
}
else
{
    <div class="profile-page">
        @if (_isOwnProfile)
        {
            <input type="checkbox"
                   id="profile-edit-team"
                   class="profile-edit-toggle"
                   aria-hidden="true"
                   tabindex="-1" />
            <input type="checkbox"
                   id="profile-edit-player"
                   class="profile-edit-toggle"
                   aria-hidden="true"
                   tabindex="-1" />
        }

        <div class="profile-card">
            <div class="profile-avatar" style="background: @AvatarColor">
                <span class="profile-avatar__initials">@Initials</span>
            </div>

            <div class="profile-info">
                <h1 class="profile-name">
                    @_profile.DisplayName
                    @if (_isOwnProfile)
                    {
                        <span class="profile-own-badge">Twój profil</span>
                    }
                </h1>

                <div class="profile-rank">
                    <span class="rank-badge rank-badge--@MedalClass(_profile.Position)">
                        @RankIcon(_profile.Position)
                        #@_profile.Position
                    </span>
                    <span class="profile-total-pts">@_profile.TotalPoints pkt łącznie</span>
                </div>

                <div class="profile-stats">
                    <div class="stat-item">
                        <span class="stat-icon">⚽</span>
                        <span class="stat-value">@_profile.PredictionPoints</span>
                        <span class="stat-label">typy</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-icon">★</span>
                        <span class="stat-value">@_profile.TeamBonusPoints</span>
                        <span class="stat-label">bonus drużyna</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-icon">👟</span>
                        <span class="stat-value">@_profile.PlayerGoalPoints</span>
                        <span class="stat-label">gole zawodnika</span>
                    </div>
                    @if (_profile.TournamentWinnerPoints > 0)
                    {
                        <div class="stat-item">
                            <span class="stat-icon">🏆</span>
                            <span class="stat-value">@_profile.TournamentWinnerPoints</span>
                            <span class="stat-label">mistrz</span>
                        </div>
                    }
                </div>
            </div>

            <div class="profile-selections">
                <div class="selection-row">
                    <div class="selection-item">
                        @if (_profile.SelectedTeamId is not null && !string.IsNullOrEmpty(_profile.SelectedTeamFlagUrl))
                        {
                            <img src="@_profile.SelectedTeamFlagUrl"
                                 alt="@_profile.SelectedTeamName"
                                 class="selection-flag" />
                        }
                        else if (_profile.SelectedTeamId is not null)
                        {
                            <div class="selection-flag selection-flag--placeholder">🏳</div>
                        }
                        else
                        {
                            <div class="selection-flag selection-flag--placeholder selection-flag--empty">—</div>
                        }
                        <div class="selection-details">
                            <span class="selection-label">Reprezentacja</span>
                            <span class="selection-value">
                                @(_profile.SelectedTeamName ?? (_isOwnProfile ? "Nie wybrano" : "—"))
                            </span>
                        </div>
                    </div>
                    @if (_isOwnProfile)
                    {
                        <label for="profile-edit-team"
                               class="selection-edit-btn"
                               title="Zmień reprezentację">
                            ✏️
                        </label>
                    }
                </div>

                <div class="selection-row">
                    <div class="selection-item">
                        @if (_profile.SelectedPlayerName is not null)
                        {
                            <div class="selection-jersey">
                                @(_profile.SelectedPlayerNumber?.ToString() ?? "—")
                            </div>
                        }
                        else
                        {
                            <div class="selection-jersey selection-jersey--empty">—</div>
                        }
                        <div class="selection-details">
                            <span class="selection-label">Zawodnik</span>
                            <span class="selection-value">
                                @(_profile.SelectedPlayerName ?? (_isOwnProfile ? "Nie wybrano" : "—"))
                            </span>
                        </div>
                    </div>
                    @if (_isOwnProfile)
                    {
                        <label for="profile-edit-player"
                               class="selection-edit-btn"
                               title="Zmień zawodnika">
                            ✏️
                        </label>
                    }
                </div>

                @if (!_isOwnProfile && _profile.SelectedTeamId is null && _profile.SelectedPlayerName is null)
                {
                    <p class="selection-empty">Gracz nie wybrał jeszcze reprezentacji ani zawodnika.</p>
                }
            </div>
        </div>

        @if (_isOwnProfile)
        {
            <div class="selection-picker selection-picker--team">
                    @if (!string.IsNullOrEmpty(_selectionMessage))
                    {
                        <div class="selection-picker__feedback selection-picker__feedback--@(_selectionError ? "error" : "success")">
                            @_selectionMessage
                        </div>
                    }
                    @if (_teams is null)
                    {
                        <p class="selection-picker__loading">Ładowanie reprezentacji…</p>
                    }
                    else
                    {
                        @foreach (var group in _teams.GroupBy(t => t.GroupName ?? "").OrderBy(g => g.Key))
                        {
                            <div class="selection-picker__group">
                                <h4 class="selection-picker__group-title">Grupa @group.Key</h4>
                                <div class="selection-picker__teams">
                                    @foreach (var team in group)
                                    {
                                        var isSelected = _profile.SelectedTeamId == team.Id;
                                        <button type="button"
                                                class="selection-picker__team @(isSelected ? "selection-picker__team--selected" : "")"
                                                @onclick="() => SelectTeamAsync(team)">
                                            @if (!string.IsNullOrEmpty(team.FlagUrl))
                                            {
                                                <img src="@team.FlagUrl" alt="" class="selection-picker__team-flag" />
                                            }
                                            <span>@team.Name</span>
                                            @if (isSelected) { <span class="selection-picker__check">✓</span> }
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }

        @if (_isOwnProfile)
        {
            <div class="selection-picker selection-picker--player">
                    @if (!string.IsNullOrEmpty(_selectionMessage))
                    {
                        <div class="selection-picker__feedback selection-picker__feedback--@(_selectionError ? "error" : "success")">
                            @_selectionMessage
                        </div>
                    }

                    <div class="selection-picker__search">
                        <input type="text"
                               class="selection-picker__search-input"
                               placeholder="Szukaj zawodników…"
                               value="@_playerSearch"
                               @oninput="OnPlayerSearchInput" />
                        @if (_playerSearch.Length > 0 && _playerSearch.Trim().Length < 2)
                        {
                            <span class="selection-picker__search-hint">Wpisz co najmniej 2 znaki</span>
                        }
                    </div>

                    @if (_playersLoading || _displayedPlayers is null)
                    {
                        <p class="selection-picker__loading">Ładowanie zawodników…</p>
                    }
                    else if (_displayedPlayers.Count == 0)
                    {
                        <p class="selection-picker__empty">
                            @if (string.IsNullOrWhiteSpace(_playerSearch) || _playerSearch.Trim().Length < 2)
                            {
                                @:Brak zawodników oznaczonych jako MVP. Użyj wyszukiwarki.
                            }
                            else
                            {
                                @:Nie znaleziono zawodników dla „@_playerSearch.Trim()”.
                            }
                        </p>
                    }
                    else
                    {
                        @if (IsShowingMvpList)
                        {
                            <p class="selection-picker__section-label">Najlepsi zawodnicy (MVP)</p>
                        }
                        else
                        {
                            <p class="selection-picker__section-label">Wyniki wyszukiwania</p>
                        }
                        <div class="player-picker-grid">
                            @foreach (var player in _displayedPlayers)
                            {
                                var isSelected = _profile.SelectedPlayerId == player.Id;
                                <button type="button"
                                        class="player-picker-card @(isSelected ? "player-picker-card--selected" : "")"
                                        @onclick="() => SelectPlayerAsync(player)">
                                    <span class="player-picker-card__number">#@player.JerseyNumber</span>
                                    <div class="player-picker-card__info">
                                        <span class="player-picker-card__name">@player.FirstName @player.LastName</span>
                                        @if (!string.IsNullOrEmpty(player.TeamName))
                                        {
                                            <span class="player-picker-card__team">@player.TeamName</span>
                                        }
                                        @if (!string.IsNullOrEmpty(player.Position))
                                        {
                                            <span class="player-picker-card__position">@PositionLabel(player.Position)</span>
                                        }
                                    </div>
                                    @if (isSelected)
                                    {
                                        <span class="player-picker-card__check">✓</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
        }

        <div class="profile-history">
            <h2 class="history-title">Historia typów</h2>

            @if (_profile.PredictionHistory.Count == 0)
            {
                <p class="history-empty">Brak rozliczonych typów.</p>
            }
            else
            {
                <div class="history-table-wrapper">
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Mecz</th>
                                <th>Wynik</th>
                                <th>Typ</th>
                                <th title="Suma punktów">Pkt</th>
                                <th title="Punkty bazowe">⚽</th>
                                <th title="Bonus drużyna">★</th>
                                <th title="Gole zawodnika">👟</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in _profile.PredictionHistory)
                            {
                                <tr class="history-row history-row--@PtsClass(h.PointsAwarded)">
                                    <td class="col-date">
                                        @h.KickOffUtc.ToLocalTime().ToString("dd.MM")
                                    </td>
                                    <td class="col-match">
                                        <span class="match-teams">
                                            @if (!string.IsNullOrEmpty(h.HomeTeamFlagUrl))
                                            {
                                                <img src="@h.HomeTeamFlagUrl" alt="" class="hist-flag" />
                                            }
                                            <span class="team-name">@h.HomeTeamName</span>
                                            <span class="vs">vs</span>
                                            <span class="team-name">@h.AwayTeamName</span>
                                            @if (!string.IsNullOrEmpty(h.AwayTeamFlagUrl))
                                            {
                                                <img src="@h.AwayTeamFlagUrl" alt="" class="hist-flag" />
                                            }
                                        </span>
                                    </td>
                                    <td class="col-score">
                                        <strong>@h.HomeScore–@h.AwayScore</strong>
                                    </td>
                                    <td class="col-pred @PredClass(h)">
                                        @h.PredictedHomeScore–@h.PredictedAwayScore
                                    </td>
                                    <td class="col-pts total">@(h.PointsAwarded ?? 0)</td>
                                    <td class="col-pts sub">@(h.BasePoints ?? 0)</td>
                                    <td class="col-pts sub">@(h.TeamBonusPoints ?? 0)</td>
                                    <td class="col-pts sub">@(h.PlayerGoalPoints ?? 0)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="history-summary">
                    <span>Rozliczone mecze: <strong>@_profile.PredictionHistory.Count</strong></span>
                    <span>Trafionych wyników: <strong>@_profile.PredictionHistory.Count(h => h.BasePoints is > 0)</strong></span>
                    <span>Dokładnych wyników: <strong>@_profile.PredictionHistory.Count(h => h.PointsAwarded >= 5)</strong></span>
                </div>
            }
        </div>

    </div>
}

@code {
    [Parameter] public string? UserId { get; set; }

    private UserPublicProfileDto? _profile;
    private bool _loading = true;
    private bool _isOwnProfile;
    private string? _currentUserId;
    private string? _effectiveUserId;

    private IReadOnlyList<TeamDto>? _teams;
    private IReadOnlyList<PlayerDto>? _displayedPlayers;
    private IReadOnlyList<PlayerDto>? _mvpPlayers;
    private string _playerSearch = "";
    private string? _selectionMessage;
    private bool _selectionError;
    private bool _ownProfileDataLoaded;
    private bool _playersLoading;
    private CancellationTokenSource? _searchDebounceCts;
    private readonly SemaphoreSlim _playerLoadGate = new(1, 1);

    private string PageTitleText => _isOwnProfile ? "Profil" : "Profil gracza";

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        _effectiveUserId = UserId;
        if (string.IsNullOrEmpty(_effectiveUserId))
        {
            if (_currentUserId is null)
            {
                Nav.NavigateTo("/logowanie", true);
                return;
            }
            _effectiveUserId = _currentUserId;
        }

        _isOwnProfile = _currentUserId == _effectiveUserId;
        await ReloadProfileAsync();
        await EnsureOwnProfileDataAsync();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !_isOwnProfile || _ownProfileDataLoaded)
            return;

        await EnsureOwnProfileDataAsync();
        if (_ownProfileDataLoaded)
            await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            var authState = await task;
            _currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            var wasOwnProfile = _isOwnProfile;
            _isOwnProfile = _currentUserId == _effectiveUserId;

            if (_isOwnProfile && !wasOwnProfile)
            {
                await EnsureOwnProfileDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Ignore auth callback failures — user can refresh manually.
        }
    }

    private async Task EnsureOwnProfileDataAsync()
    {
        if (!_isOwnProfile || _ownProfileDataLoaded)
            return;

        await _playerLoadGate.WaitAsync();
        try
        {
            if (_ownProfileDataLoaded)
                return;

            _mvpPlayers = await PlayerService.GetMvpsAsync();
            _teams ??= await TeamService.GetAllAsync();
            _displayedPlayers = _mvpPlayers;
            _ownProfileDataLoaded = true;
        }
        finally
        {
            _playerLoadGate.Release();
        }
    }

    private bool IsShowingMvpList =>
        string.IsNullOrWhiteSpace(_playerSearch) || _playerSearch.Trim().Length < 2;

    private async Task ReloadProfileAsync()
    {
        if (_effectiveUserId is null) return;
        _profile = await UserProfileService.GetPublicProfileAsync(_effectiveUserId);
    }

    private async Task OnPlayerSearchInput(ChangeEventArgs e)
    {
        _playerSearch = e.Value?.ToString() ?? string.Empty;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();
        var token = _searchDebounceCts.Token;

        try
        {
            await Task.Delay(300, token);
            await LoadDisplayedPlayersAsync(token);
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // Expected when the user keeps typing.
        }
    }

    private async Task LoadDisplayedPlayersAsync(CancellationToken cancellationToken = default)
    {
        if (!_isOwnProfile)
            return;

        await _playerLoadGate.WaitAsync(cancellationToken);
        try
        {
            _playersLoading = true;
            _selectionMessage = null;

            if (IsShowingMvpList)
            {
                _displayedPlayers = _mvpPlayers ?? await PlayerService.GetMvpsAsync(cancellationToken);
                _mvpPlayers ??= _displayedPlayers;
            }
            else
            {
                _displayedPlayers = await PlayerService.SearchAsync(_playerSearch.Trim(), cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch
        {
            _selectionMessage = "Nie udało się wyszukać zawodników. Spróbuj ponownie.";
            _selectionError = true;
        }
        finally
        {
            _playersLoading = false;
            _playerLoadGate.Release();
        }
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _playerLoadGate.Dispose();
    }

    private static string PositionLabel(string pos) => pos.ToUpperInvariant() switch
    {
        "GK" or "GOALKEEPER" or "BRAMKARZ" => "Bramkarz",
        "DEF" or "DEFENDER" or "OBROŃCA" => "Obrońca",
        "MID" or "MIDFIELDER" or "POMOCNIK" => "Pomocnik",
        "FWD" or "FORWARD" or "NAPASTNIK" => "Napastnik",
        _ => pos
    };

    private async Task SelectTeamAsync(TeamDto team)
    {
        if (_effectiveUserId is null) return;

        var result = await TeamService.SelectTeamAsync(_effectiveUserId, new SelectTeamRequest(team.Id));
        if (result.Succeeded)
        {
            _selectionMessage = $"Wybrano: {team.Name}";
            _selectionError = false;
            await ReloadProfileAsync();
        }
        else
        {
            _selectionMessage = result.Error ?? "Wystąpił błąd.";
            _selectionError = true;
        }
    }

    private async Task SelectPlayerAsync(PlayerDto player)
    {
        if (_effectiveUserId is null) return;

        var result = await PlayerService.SelectPlayerAsync(_effectiveUserId, new SelectPlayerRequest(player.Id));
        if (result.Succeeded)
        {
            _selectionMessage = $"Wybrano: {player.FirstName} {player.LastName}";
            _selectionError = false;
            await ReloadProfileAsync();
        }
        else
        {
            _selectionMessage = result.Error ?? "Wystąpił błąd.";
            _selectionError = true;
        }
    }

    private string Initials => string.IsNullOrEmpty(_profile?.DisplayName)
        ? "?"
        : string.Concat(_profile.DisplayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(w => char.ToUpper(w[0])));

    private string AvatarColor
    {
        get
        {
            if (_profile is null) return "#6b7280";
            var hash = Math.Abs(_profile.UserId.GetHashCode());
            string[] palette =
            [
                "#3b82f6","#8b5cf6","#ec4899","#f59e0b",
                "#10b981","#06b6d4","#f97316","#6366f1",
                "#84cc16","#e11d48","#0ea5e9","#a855f7"
            ];
            return palette[hash % palette.Length];
        }
    }

    private static string MedalClass(int pos) => pos switch
    {
        1 => "gold", 2 => "silver", 3 => "bronze", _ => "other"
    };

    private static string RankIcon(int pos) => pos switch
    {
        1 => "🥇", 2 => "🥈", 3 => "🥉", _ => string.Empty
    };

    private static string PtsClass(int? pts) => pts switch
    {
        >= 5 => "high", >= 1 => "mid", _ => "low"
    };

    private static string PredClass(UserPredictionHistoryDto h)
    {
        if (h.PointsAwarded is null) return string.Empty;
        if (h.PredictedHomeScore == h.HomeScore && h.PredictedAwayScore == h.AwayScore)
            return "pred--exact";
        if (h.BasePoints is > 0)
            return "pred--correct";
        return "pred--wrong";
    }
}
