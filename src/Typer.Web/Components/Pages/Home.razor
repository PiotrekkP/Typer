@page "/"
@using Typer.Application.Matches.Interfaces
@using Typer.Application.Matches.DTOs
@using Typer.Application.Rankings.DTOs
@using Typer.Application.UserProfile.DTOs
@inject IMatchService MatchService
@inject IRankingService RankingService
@inject IUserProfileService UserProfileService
@inject IPredictionService PredictionService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISelectionLockService SelectionLockService

<PageTitle>Typer — Liga typowania</PageTitle>

<div class="dashboard">

    <!-- ══ LEWY GÓRNY: Nadchodzące mecze ══════════════════════════ -->
    <div class="dash-widget dash-widget--upcoming">
        <div class="dash-widget__header">
            <h2 class="dash-widget__title">⚽ Najbliższe mecze</h2>
            <a href="/typowanie" class="dash-widget__link">Wszystkie →</a>
        </div>
        <div class="dash-widget__body">
            @if (_upcoming is null)
            {
                <p class="dash-loading">Ładowanie…</p>
            }
            else if (_upcoming.Count == 0)
            {
                <p class="dash-empty">Brak nadchodzących meczów.</p>
            }
            else
            {
                @foreach (var match in _upcoming)
                {
                    <MatchCard Match="match"
                               IsAuthenticated="_isAuthenticated"
                               OnPredictionSubmit="HandlePredictionSubmit" />
                }
            }
        </div>
    </div>

    <!-- ══ PRAWY GÓRNY: Mini-ranking ══════════════════════════════ -->
    <div class="dash-widget dash-widget--ranking">
        <div class="dash-widget__header">
            <h2 class="dash-widget__title">🏆 Ranking</h2>
            <a href="/ranking" class="dash-widget__link">Pełny ranking →</a>
        </div>
        <div class="dash-widget__body">
            @if (_ranking is null)
            {
                <p class="dash-loading">Ładowanie…</p>
            }
            else if (_ranking.Count == 0)
            {
                <p class="dash-empty">Ranking jest pusty.</p>
            }
            else
            {
                <table class="mini-ranking">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Gracz</th>
                            <th>Repr.</th>
                            <th class="pts-col">Pkt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _ranking.Take(10))
                        {
                            <tr class="@(entry.UserId == _userId ? "mini-ranking__me" : "")">
                                <td class="pos-cell">@MedalOrPos(entry.Position)</td>
                                <td>@entry.DisplayName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(entry.TeamFlagUrl))
                                    {
                                        <img src="@entry.TeamFlagUrl" alt="@entry.TeamName"
                                             style="width:18px;height:13px;object-fit:cover;border-radius:2px;vertical-align:middle;" />
                                    }
                                </td>
                                <td class="pts-col"><strong>@entry.TotalPoints</strong></td>
                            </tr>
                        }
                        @if (_userEntry is not null && _userEntry.Position > 10)
                        {
                            <tr class="mini-ranking__separator"><td colspan="4">…</td></tr>
                            <tr class="mini-ranking__me">
                                <td class="pos-cell">@_userEntry.Position</td>
                                <td>@_userEntry.DisplayName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(_userEntry.TeamFlagUrl))
                                    {
                                        <img src="@_userEntry.TeamFlagUrl" alt="@_userEntry.TeamName"
                                             style="width:18px;height:13px;object-fit:cover;border-radius:2px;vertical-align:middle;" />
                                    }
                                </td>
                                <td class="pts-col"><strong>@_userEntry.TotalPoints</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!_isAuthenticated)
                {
                    <p class="dash-guest-note">
                        <a href="/logowanie">Zaloguj się</a>, żeby zobaczyć swoją pozycję.
                    </p>
                }
            }
        </div>
    </div>

    <!-- ══ LEWY DOLNY: Ostatnie wyniki ═══════════════════════════ -->
    <div class="dash-widget dash-widget--recent">
        <div class="dash-widget__header">
            <h2 class="dash-widget__title">📋 Ostatnie wyniki</h2>
        </div>
        <div class="dash-widget__body">
            @if (_recent is null)
            {
                <p class="dash-loading">Ładowanie…</p>
            }
            else if (_recent.Count == 0)
            {
                <p class="dash-empty">Brak zakończonych meczów.</p>
            }
            else
            {
                @foreach (var m in _recent)
                {
                    <div class="recent-result">
                        <div class="recent-result__team recent-result__team--home">
                            @if (!string.IsNullOrEmpty(m.HomeTeamFlagUrl))
                            {
                                <img src="@m.HomeTeamFlagUrl" alt="" class="recent-result__flag" />
                            }
                            <span class="recent-result__name">@m.HomeTeamName</span>
                        </div>
                        <span class="recent-result__score">@m.HomeScore – @m.AwayScore</span>
                        <div class="recent-result__team recent-result__team--away">
                            <span class="recent-result__name">@m.AwayTeamName</span>
                            @if (!string.IsNullOrEmpty(m.AwayTeamFlagUrl))
                            {
                                <img src="@m.AwayTeamFlagUrl" alt="" class="recent-result__flag" />
                            }
                        </div>
                        @if (m.GoalScorers.Any())
                        {
                            <div class="recent-result__goals recent-result__goals--home">
                                @foreach (var g in m.GoalScorers.Where(x => x.IsHomeTeam).OrderBy(x => x.Minute))
                                {
                                    <span class="goal-entry">
                                        <span class="goal-name">@g.PlayerName@GoalSuffix(g)</span>
                                        <span class="goal-minute">⚽ @g.Minute'</span>
                                    </span>
                                }
                            </div>
                            <div class="recent-result__goals recent-result__goals--away">
                                @foreach (var g in m.GoalScorers.Where(x => !x.IsHomeTeam).OrderBy(x => x.Minute))
                                {
                                    <span class="goal-entry">
                                        <span class="goal-minute">@g.Minute' ⚽</span>
                                        <span class="goal-name">@g.PlayerName@GoalSuffix(g)</span>
                                    </span>
                                }
                            </div>
                        }
                        @if (_isAuthenticated && m.PointsAwarded.HasValue)
                        {
                            <span class="recent-result__pts recent-result__pts--@PtsClass(m.PointsAwarded.Value)">
                                +@m.PointsAwarded pkt
                            </span>
                        }
                        else if (_isAuthenticated && m.PredictedHomeScore.HasValue)
                        {
                            <span class="recent-result__pred">
                                Typ: @m.PredictedHomeScore–@m.PredictedAwayScore
                            </span>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- ══ PRAWY DOLNY: Moja drużyna ══════════════════════════════ -->
    <div class="dash-widget dash-widget--profile">
        <div class="dash-widget__header">
            <h2 class="dash-widget__title">🌍 Moja drużyna</h2>
        </div>
        <div class="dash-widget__body">
            @if (!_isAuthenticated)
            {
                <p class="dash-empty">
                    <a href="/logowanie">Zaloguj się</a>, żeby wybrać reprezentację i zawodnika.
                </p>
            }
            else if (_selection is null)
            {
                <p class="dash-loading">Ładowanie…</p>
            }
            else if (_selection.SelectedTeamId is null)
            {
                <p class="dash-empty">
                    @if (_selectionOpen)
                    {
                        @:Nie wybrałeś jeszcze reprezentacji.<br />
                        <a href="/profil">Wybierz teraz →</a>
                    }
                    else
                    {
                        @:Nie wybrałeś reprezentacji przed startem turnieju.
                    }
                </p>
            }
            else
            {
                <div class="profile-split">
                    <div class="profile-split__half profile-split__half--team">
                        @if (!string.IsNullOrEmpty(_selection.SelectedTeamFlagUrl))
                        {
                            <img src="@_selection.SelectedTeamFlagUrl"
                                 alt="@_selection.SelectedTeamName"
                                 class="profile-split__flag" />
                        }
                        <div class="profile-split__label">Reprezentacja</div>
                        <div class="profile-split__name">@_selection.SelectedTeamName</div>
                        <div class="profile-split__pts">
                            <span class="profile-split__pts-value">@_selection.TeamBonusPoints</span>
                            <span class="profile-split__pts-label">pkt za mecze</span>
                        </div>
                    </div>
                    <div class="profile-split__divider"></div>
                    <div class="profile-split__half profile-split__half--player">
                        @if (_selection.SelectedPlayerId is not null)
                        {
                            @if (!string.IsNullOrEmpty(_selection.SelectedPlayerPhotoUrl) && !_playerPhotoFailed)
                            {
                                <img src="@_selection.SelectedPlayerPhotoUrl"
                                     alt="@_selection.SelectedPlayerName"
                                     class="profile-split__photo"
                                     referrerpolicy="no-referrer"
                                     loading="lazy"
                                     @onerror="OnPlayerPhotoError" />
                            }
                            else
                            {
                                <div class="profile-split__photo profile-split__photo--placeholder">
                                    #@(_selection.SelectedPlayerNumber?.ToString() ?? "—")
                                </div>
                            }
                            <div class="profile-split__label">Zawodnik</div>
                            <div class="profile-split__name">@_selection.SelectedPlayerName</div>
                            <div class="profile-split__pts">
                                <span class="profile-split__pts-value">@_selection.PlayerGoalPoints</span>
                                <span class="profile-split__pts-label">pkt za bramki</span>
                            </div>
                        }
                        else
                        {
                            <div class="profile-split__photo profile-split__photo--placeholder">—</div>
                            <div class="profile-split__label">Zawodnik</div>
                            <div class="profile-split__name profile-split__name--empty">
                                @if (_selectionOpen)
                                {
                                    <a href="/profil">Wybierz zawodnika →</a>
                                }
                                else
                                {
                                    @:Nie wybrano przed startem turnieju
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="profile-links">
                    <a href="/profil">Edytuj profil →</a>
                </div>
            }
        </div>
    </div>

</div>

@code {
    private IReadOnlyList<MatchDetailDto>? _upcoming;
    private IReadOnlyList<MatchDetailDto>? _recent;
    private IReadOnlyList<RankingEntryDto>? _ranking;
    private RankingEntryDto? _userEntry;
    private UserSelectionDto? _selection;

    private bool _isAuthenticated;
    private bool _selectionOpen = true;
    private string? _userId;
    private bool _playerPhotoFailed;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = auth.User.Identity?.IsAuthenticated ?? false;
        _userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        await LoadUpcomingAsync();
        await LoadRecentAsync();
        await LoadRankingAsync();
        await LoadSelectionAsync();
    }

    private async Task LoadUpcomingAsync()
        => _upcoming = await MatchService.GetUpcomingMatchesAsync(2, _userId);

    private async Task LoadRecentAsync()
        => _recent = await MatchService.GetRecentFinishedMatchesAsync(3, _userId);

    private async Task LoadRankingAsync()
    {
        _ranking = await RankingService.GetLeaderboardAsync();
        if (_userId is not null)
            _userEntry = _ranking.FirstOrDefault(e => e.UserId == _userId);
    }

    private async Task LoadSelectionAsync()
    {
        _playerPhotoFailed = false;
        if (_userId is not null)
        {
            _selection = await UserProfileService.GetSelectionAsync(_userId);
            _selectionOpen = await SelectionLockService.IsSelectionOpenAsync();
        }
        else
        {
            _selection = new UserSelectionDto(null, null, null, null, null, null, null, null, 0, 0, 0);
            _selectionOpen = true;
        }
    }

    private void OnPlayerPhotoError()
    {
        _playerPhotoFailed = true;
        StateHasChanged();
    }

    private async Task HandlePredictionSubmit((Guid MatchId, int Home, int Away) args)
    {
        if (_userId is null) return;
        await PredictionService.SubmitAsync(_userId, new SubmitPredictionRequest(args.MatchId, args.Home, args.Away), CancellationToken.None);
        _upcoming = await MatchService.GetUpcomingMatchesAsync(2, _userId);
    }

    private static string MedalOrPos(int pos) => pos switch
    {
        1 => "🥇", 2 => "🥈", 3 => "🥉", _ => pos.ToString()
    };

    private static string PtsClass(int pts) => pts switch
    {
        >= 5 => "high", >= 2 => "mid", _ => "low"
    };

    private static string GoalSuffix(GoalScorerDto g) => (g.IsOwnGoal, g.IsPenalty) switch
    {
        (true, _) => " (sam.)",
        (_, true) => " (k.)",
        _ => ""
    };
}
