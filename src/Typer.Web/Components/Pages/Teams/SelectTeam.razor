@page "/reprezentacje"
@rendermode InteractiveServer
@using System.Security.Claims
@using Typer.Application.Teams.DTOs
@using Typer.Application.Teams.Interfaces
@using Typer.Application.UserProfile.DTOs
@using Typer.Application.UserProfile.Interfaces
@inject ITeamService TeamService
@inject IUserProfileService UserProfileService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Reprezentacje — Typer</PageTitle>

<div class="selection-page">

    <div class="selection-header">
        <h1 class="selection-title">Wybierz reprezentację</h1>
        <p class="selection-subtitle">
            Typowania meczów Twojej drużyny liczą się podwójnie!
        </p>
    </div>

    @if (!_isAuthenticated)
    {
        <div class="selection-auth-prompt">
            <p>Musisz być <a href="/logowanie">zalogowany</a>, żeby wybrać reprezentację.</p>
        </div>
    }
    else
    {
        @if (_selection?.SelectedTeamId is not null)
        {
            <div class="current-selection">
                <span class="current-selection__label">Twój wybór:</span>
                @if (!string.IsNullOrEmpty(_selection.SelectedTeamFlagUrl))
                {
                    <img src="@_selection.SelectedTeamFlagUrl" alt="@_selection.SelectedTeamName"
                         style="width:28px;height:20px;object-fit:cover;border-radius:3px;vertical-align:middle;" />
                }
                <span class="current-selection__value">
                    @_selection.SelectedTeamName (@_selection.SelectedTeamCode)
                </span>
                @if (_selection.SelectedPlayerId is not null)
                {
                    <span class="current-selection__player">
                        · Zawodnik: #@_selection.SelectedPlayerNumber @_selection.SelectedPlayerName
                    </span>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="selection-feedback selection-feedback--@(_isError ? "error" : "success")">
                @_message
            </div>
        }

        @if (_teams is null)
        {
            <p class="loading">Ładowanie reprezentacji…</p>
        }
        else if (_teams.Count == 0)
        {
            <p>Brak reprezentacji w bazie danych.</p>
        }
        else
        {
            @foreach (var group in _teams.GroupBy(t => t.GroupName ?? "").OrderBy(g => g.Key))
            {
                <div class="group-section">
                    <h3 class="group-title">Grupa @group.Key</h3>
                    <div class="teams-grid">
                        @foreach (var team in group)
                        {
                            var isSelected = _selection?.SelectedTeamId == team.Id;
                            <button class="team-card @(isSelected ? "team-card--selected" : "")"
                                    @onclick="() => SelectTeamAsync(team)">

                                @if (!string.IsNullOrEmpty(team.FlagUrl))
                                {
                                    <img src="@team.FlagUrl" alt="@team.Name" class="team-card__flag" />
                                }
                                else
                                {
                                    <div class="team-card__flag-placeholder">🏳</div>
                                }

                                <div class="team-card__info">
                                    <span class="team-card__name">@team.Name</span>
                                </div>

                                @if (isSelected)
                                {
                                    <span class="team-card__check">✓</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }

            @if (_selection?.SelectedTeamId is not null)
            {
                <div class="selection-next">
                    <a href="/zawodnicy" class="btn-next">
                        Wybierz zawodnika →
                    </a>
                </div>
            }
        }
    }

</div>

@code {
    private IReadOnlyList<TeamDto>? _teams;
    private UserSelectionDto? _selection;
    private bool _isAuthenticated;
    private string? _userId;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        _userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        _teams = await TeamService.GetAllAsync();

        if (_userId is not null)
            _selection = await UserProfileService.GetSelectionAsync(_userId);
    }

    private async Task SelectTeamAsync(TeamDto team)
    {
        if (_userId is null) return;

        var result = await TeamService.SelectTeamAsync(_userId, new SelectTeamRequest(team.Id));

        if (result.Succeeded)
        {
            _message = $"Wybrano: {team.Name}. Teraz wybierz zawodnika!";
            _isError = false;
            _selection = await UserProfileService.GetSelectionAsync(_userId);
        }
        else
        {
            _message = result.Error ?? "Wystąpił błąd.";
            _isError = true;
        }
    }
}
