@page "/logowanie"
@inject NavigationManager Nav

<PageTitle>Logowanie — Typer</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-card__header">
            <span class="auth-card__icon">⚽</span>
            <h1 class="auth-card__title">Logowanie</h1>
            <p class="auth-card__subtitle">Wpisz swoje dane, żeby typować wyniki.</p>
        </div>

        @if (ErrorMessage is not null)
        {
            <div class="auth-error">@ErrorMessage</div>
        }

        <form method="post" action="/account/login" class="auth-form">

            <div class="form-group">
                <label for="email">Adres e-mail</label>
                <input id="email" name="email" type="email"
                       class="form-input" placeholder="jan@example.com"
                       required autocomplete="email" />
            </div>

            <div class="form-group">
                <label for="password">Hasło</label>
                <input id="password" name="password" type="password"
                       class="form-input" placeholder="••••••••"
                       required autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-auth">Zaloguj się</button>

        </form>

        <p class="auth-card__footer">
            Nie masz konta?
            <a href="/rejestracja">Zarejestruj się</a>
        </p>

    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    private string? ErrorMessage => Error switch
    {
        "invalid" => "Nieprawidłowy adres e-mail lub hasło.",
        _         => null
    };
}
