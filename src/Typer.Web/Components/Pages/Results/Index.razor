@page "/historia"
@implements IAsyncDisposable
@inject IMatchService MatchService
@inject IWebHostEnvironment HostEnvironment
@using Typer.Application.Matches
@using Typer.Application.Matches.DTOs
@using Typer.Domain.Enums

<PageTitle>Historia — Typer</PageTitle>

<h1 class="page-title">Historia typów</h1>

<div class="results-page">
    @if (_matches is null)
    {
        <p class="results-loading">Ładowanie meczów…</p>
    }
    else if (_matches.Count == 0)
    {
        <p class="results-empty">Brak rozpoczętych lub zakończonych meczów.</p>
    }
    else
    {
        <div class="results-toolbar">
            <label class="results-select-label" for="results-match-select">Mecz</label>
            <select id="results-match-select"
                    class="results-select"
                    @onchange="OnMatchSelectedAsync">
                @if (_liveMatches.Any())
                {
                    <optgroup label="Na żywo">
                        @foreach (var match in _liveMatches)
                        {
                            <option value="@match.MatchId" selected="@(match.MatchId == _selectedMatchId)">
                                @FormatMatchOption(match)
                            </option>
                        }
                    </optgroup>
                }
                @if (_finishedMatches.Any())
                {
                    <optgroup label="Historia">
                        @foreach (var match in _finishedMatches)
                        {
                            <option value="@match.MatchId" selected="@(match.MatchId == _selectedMatchId)">
                                @FormatMatchOption(match)
                            </option>
                        }
                    </optgroup>
                }
            </select>
        </div>

        @if (_selectedMatch is not null)
        {
            <div class="results-match-header">
                <div class="results-match-teams">
                    @if (!string.IsNullOrEmpty(_selectedMatch.HomeTeamFlagUrl))
                    {
                        <img src="@_selectedMatch.HomeTeamFlagUrl" alt="" class="results-flag" width="28" height="20" />
                    }
                    <span class="results-team-name">
                        <a href="/statystyki/druzyna/@_selectedMatch.HomeTeamId" class="team-link">@_selectedMatch.HomeTeamName</a>
                    </span>
                    <span class="results-score">
                        @if (_selectedMatch.HomeScore.HasValue && _selectedMatch.AwayScore.HasValue)
                        {
                            @($"{_selectedMatch.HomeScore}:{_selectedMatch.AwayScore}")
                        }
                        else
                        {
                            <text>vs</text>
                        }
                    </span>
                    <span class="results-team-name">
                        <a href="/statystyki/druzyna/@_selectedMatch.AwayTeamId" class="team-link">@_selectedMatch.AwayTeamName</a>
                    </span>
                    @if (!string.IsNullOrEmpty(_selectedMatch.AwayTeamFlagUrl))
                    {
                        <img src="@_selectedMatch.AwayTeamFlagUrl" alt="" class="results-flag" width="28" height="20" />
                    }
                </div>
                <div class="results-match-meta">
                    <span>@_selectedMatch.RoundName</span>
                    <span>·</span>
                    <span>@DisplayTimeRules.FormatPolandTime(_selectedMatch.KickOffUtc, "dd.MM.yyyy HH:mm")</span>
                    <span>·</span>
                    <span class="results-status results-status--@_selectedMatch.Status.ToLowerInvariant()">
                        @StatusLabel(_selectedMatch.Status)
                    </span>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_loadError))
        {
            <p class="results-error">@_loadError</p>
        }
        else if (_loadingPredictions)
        {
            <p class="results-loading">Ładowanie typów…</p>
        }
        else if (_predictions.Count == 0)
        {
            <p class="results-empty">Nikt nie typował tego meczu.</p>
        }
        else
        {
            <div class="results-table-wrapper">
                <table class="results-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Gracz</th>
                            <th>Typ</th>
                            <th title="Suma punktów">Pkt</th>
                            <th title="Punkty bazowe">⚽</th>
                            <th title="Bonus drużyna">★</th>
                            <th title="Gole zawodnika">👟</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < _predictions.Count; i++)
                        {
                            var row = _predictions[i];
                            <tr class="results-row results-row--@RowClass(row)">
                                <td class="results-col-pos">@(i + 1)</td>
                                <td class="results-col-player">
                                    <a href="/gracz/@row.UserId" class="results-player-link">@row.DisplayName</a>
                                </td>
                                <td class="results-col-pred">@FormatPrediction(row)</td>
                                <td class="results-col-pts results-col-pts--total">@FormatPoints(row.PointsAwarded, _selectedMatch?.Status)</td>
                                <td class="results-col-pts">@(row.BasePoints ?? 0)</td>
                                <td class="results-col-pts">@(row.TeamBonusPoints ?? 0)</td>
                                <td class="results-col-pts">@(row.PlayerGoalPoints ?? 0)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private IReadOnlyList<ResultsMatchOptionDto> _matches = [];
    private List<MatchPredictionResultDto> _predictions = [];
    private Guid _selectedMatchId;
    private ResultsMatchOptionDto? _selectedMatch;
    private bool _loadingPredictions;
    private string? _loadError;

    private IEnumerable<ResultsMatchOptionDto> _liveMatches =>
        _matches.Where(m => m.Status == nameof(MatchStatus.InProgress));

    private IEnumerable<ResultsMatchOptionDto> _finishedMatches =>
        _matches
            .Where(m => m.Status != nameof(MatchStatus.InProgress))
            .OrderByDescending(m => MatchLifecycleRules.EnsureUtc(m.KickOffUtc));

    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _refreshCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadMatchesAsync();

        if (_matches.Count > 0)
        {
            var defaultMatch = PickDefaultMatch();
            if (defaultMatch is not null)
            {
                _selectedMatchId = defaultMatch.MatchId;
                _selectedMatch = defaultMatch;
            }

            await LoadPredictionsAsync();
        }
    }

    private async Task LoadMatchesAsync()
    {
        _matches = await MatchService.GetResultsMatchOptionsAsync();
        _selectedMatch = _matches.FirstOrDefault(m => m.MatchId == _selectedMatchId)
            ?? PickDefaultMatch();
        if (_selectedMatch is not null)
            _selectedMatchId = _selectedMatch.MatchId;

        SyncRefreshTimer();
    }

    private ResultsMatchOptionDto? PickDefaultMatch() =>
        _liveMatches.FirstOrDefault()
        ?? _finishedMatches.FirstOrDefault();

    private void SyncRefreshTimer()
    {
        if (_matches.Any(m => m.Status == nameof(MatchStatus.InProgress)))
            StartRefreshTimer();
        else
            StopRefreshTimer();
    }

    private void StartRefreshTimer()
    {
        if (_refreshTimer is not null) return;

        _refreshCts = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(LiveUiRefreshRules.GetRefreshInterval(HostEnvironment.IsDevelopment()));
        _ = RunRefreshLoopAsync(_refreshCts.Token);
    }

    private void StopRefreshTimer()
    {
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        _refreshCts = null;
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _refreshTimer!.WaitForNextTickAsync(ct))
            {
                await LoadMatchesAsync();
                if (_selectedMatchId != Guid.Empty)
                    await LoadPredictionsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        StopRefreshTimer();
        await Task.CompletedTask;
    }

    private async Task OnMatchSelectedAsync(ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var matchId))
            return;

        _selectedMatchId = matchId;
        _selectedMatch = _matches.FirstOrDefault(m => m.MatchId == matchId);
        await LoadPredictionsAsync();
    }

    private async Task LoadPredictionsAsync()
    {
        if (_selectedMatchId == Guid.Empty)
        {
            _predictions = [];
            return;
        }

        _loadingPredictions = true;
        _loadError = null;

        try
        {
            _predictions = (await MatchService.GetMatchPredictionResultsAsync(_selectedMatchId)).ToList();
        }
        catch (Exception)
        {
            _predictions = [];
            _loadError = "Nie udało się wczytać typów. Odśwież stronę.";
        }
        finally
        {
            _loadingPredictions = false;
        }
    }

    private static string FormatMatchOption(ResultsMatchOptionDto match)
    {
        var score = match.HomeScore.HasValue && match.AwayScore.HasValue
            ? $" ({match.HomeScore}:{match.AwayScore})"
            : match.Status == "InProgress" ? " (na żywo)" : string.Empty;

        return $"{match.HomeTeamName} – {match.AwayTeamName}{score} · {match.RoundName} · {DisplayTimeRules.FormatPolandTime(match.KickOffUtc, "dd.MM HH:mm")}";
    }

    private static string FormatPrediction(MatchPredictionResultDto row) =>
        $"{row.PredictedHomeScore}:{row.PredictedAwayScore}";

    private static string StatusLabel(string status) => status switch
    {
        "InProgress" => "Na żywo",
        "Finished" => "Zakończony",
        _ => status
    };

    private static string FormatPoints(int? points, string? status) =>
        points?.ToString() ?? (status == "InProgress" ? "…" : "0");

    private static string RowClass(MatchPredictionResultDto row) =>
        (row.BasePoints ?? row.PointsAwarded) switch
        {
            >= 5 => "high",
            >= 1 => "hit",
            0 => "miss",
            _ => "pending"
        };
}
