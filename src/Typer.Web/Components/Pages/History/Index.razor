@page "/wyniki"
@using System.Security.Claims
@implements IAsyncDisposable
@inject IMatchService MatchService
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment HostEnvironment
@using Typer.Application.Matches

<PageTitle>Wyniki — Typer</PageTitle>

<h1 class="page-title">Wyniki meczów</h1>

@if (_rounds is null)
{
    <p class="loading">Ładowanie wyników…</p>
}
else if (_rounds.Count == 0)
{
    <p>Brak rozpoczętych ani zakończonych meczów.</p>
}
else
{
    @foreach (var round in _rounds)
    {
        <section class="round-section">
            <h2 class="round-title">@round.Name</h2>

            <div class="matches-list">
                @foreach (var match in round.Matches)
                {
                    <MatchCard Match="match"
                               IsAuthenticated="_isAuthenticated"
                               LinkTeams="true" />
                }
            </div>
        </section>
    }
}

@if (!_isAuthenticated)
{
    <p class="guest-info">
        💡 <a href="/logowanie">Zaloguj się</a>, żeby zobaczyć swoje typy i punkty za zakończone mecze.
    </p>
}

@code {
    private IReadOnlyList<RoundWithMatchesDto>? _rounds;
    private bool _isAuthenticated;
    private string? _userId;

    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _refreshCts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        _userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        await LoadRoundsAsync();
    }

    private async Task LoadRoundsAsync()
    {
        _rounds = await MatchService.GetRoundsWithMatchesAsync(
            userId: _userId,
            scope: MatchRoundsScope.Results);

        SyncRefreshTimer();
    }

    private void SyncRefreshTimer()
    {
        if (LiveUiRefreshRules.HasLiveMatches(_rounds))
            StartRefreshTimer();
        else
            StopRefreshTimer();
    }

    private void StartRefreshTimer()
    {
        if (_refreshTimer is not null) return;

        _refreshCts = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(LiveUiRefreshRules.GetRefreshInterval(HostEnvironment.IsDevelopment()));
        _ = RunRefreshLoopAsync(_refreshCts.Token);
    }

    private void StopRefreshTimer()
    {
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        _refreshCts = null;
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _refreshTimer!.WaitForNextTickAsync(ct))
            {
                await LoadRoundsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        StopRefreshTimer();
        await Task.CompletedTask;
    }
}
