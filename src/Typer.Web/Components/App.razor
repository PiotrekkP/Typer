@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="pl">

<head>
    @{
        var gaId = Configuration["GoogleAnalytics:MeasurementId"];
    }
    @if (!string.IsNullOrWhiteSpace(gaId))
    {
        <!-- Google tag (gtag.js) -->
        <script async src="@($"https://www.googletagmanager.com/gtag/js?id={gaId}")"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@gaId');
        </script>
    }
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@($"app.css?v={StaticAssets.Version}")" />
    <link rel="stylesheet" href="@($"auth.css?v={StaticAssets.Version}")" />
    <link rel="stylesheet" href="@($"Typer.Web.styles.css?v={StaticAssets.Version}")" />
    <link rel="stylesheet" href="@($"dashboard-overrides.css?v={StaticAssets.Version}")" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="@($"site-nav.js?v={StaticAssets.Version}")"></script>
    <script src="@($"profile-edit.js?v={StaticAssets.Version}")"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
